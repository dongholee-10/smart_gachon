NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# PostgreSQL (docker-compose.yml의 db 서비스 기준)
DATABASE_URL=postgresql+psycopg2://redflag:redflag@localhost:5432/redflag
# 로컬 SQLite로 빠르게 돌려보고 싶다면 위 줄을 주석 처리하고 아래로 교체:
# DATABASE_URL=sqlite:///./redflag.db

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440
ENABLE_FINBERT=false

# Optional LLM (leave blank to use deterministic template explanations)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...     # 종목 Agent 채팅 기능에도 사용됨
# OPENAI_MODEL=gpt-4o-mini

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
